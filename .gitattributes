# Normalize line endings: text files stored as LF in the repo.
* text=auto eol=lf

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
gradlew.bat text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jks binary
*.keystore binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
